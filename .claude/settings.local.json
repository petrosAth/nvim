            {
                "matcher": "Edit|Write|MultiEdit|Bash|PowerShell",
                "hooks": [
                    {
                        "type": "command",
                        "command": "/Users/pathanasoulis/.local/share/nvim/lazy/code-preview.nvim/bin/hook-entry.sh claudecode pre"
                    }
                ]
