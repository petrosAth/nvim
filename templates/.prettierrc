{
    "singleQuote": true,
    "overrides": [
        {
            "files": "*.md",
            "options": {
                "proseWrap": "always"
            }
        },
        {
            "files": "*.mdc",
            "options": {
                "proseWrap": "always",
                "parser": "markdown"
            }
        }
    ]
}
